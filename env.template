# ========== 必須 ==========

# バックエンド API URL（nginx 経由ポート 80）
API_URL=http://localhost:3000

# NextAuth シークレット（`openssl rand -base64 32` などで生成）
AUTH_SECRET=

# Google OAuth クライアント ID / シークレット
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# クライアント識別シークレット（バックエンドと共有する固定値）
CLIENT_SECRET=

# Google Maps JavaScript API キー
GOOGLE_MAP_API_KEY=

# ========== 任意 ==========

# PaizaIO のコード実行 API キー（未設定時は "guest" にフォールバック）
PAIZAIO_API_KEY=

# Google Analytics 測定 ID（未設定時は GA タグを埋め込まない）
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Google Search Console サイト所有権確認メタタグ
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
